// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Messages de contact (formulaire principal)
model Contact {
  id        String   @id @default(cuid())
  nom       String
  email     String
  telephone String   @default("")
  message   String
  status    String   @default("nouveau") // nouveau | lu | traité | archivé
  emailSent Boolean  @default(false)
  ip        String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Demandes de rappel téléphonique
model Rappel {
  id               String   @id @default(cuid())
  prenom           String
  telephone        String
  creneau          String   // matin | midi | soir
  budget           Float?
  situation        String?
  tauxEndettement  Float?
  status           String   @default("nouveau") // nouveau | rappelé | traité | archivé
  notes            String   @default("")
  emailSent        Boolean  @default(false)
  webhookSent      Boolean  @default(false)
  ip               String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Leads capturés (email gate PDF + comparateur)
model Lead {
  id        String   @id @default(cuid())
  email     String
  prenom    String   @default("")
  source    String   // comparateur | simulateur-a | simulateur-b | carte | aides
  contexte  String   @default("") // JSON libre : budget, score, nb biens, etc.
  emailSent Boolean  @default(false)
  ip        String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([source])
}

/// Abonnés newsletter blog
model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  status       String   @default("active") // active | unsubscribed
  source       String   @default("blog")   // blog | article | homepage
  ip           String   @default("")
  subscribedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([status])
}

/// Événements analytics anonymes (usage outils, simulations, conversions)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // simulation-a | simulation-b | comparaison | carte-view | aides-check | lead-capture | contact-form | rappel-form
  data      String   @default("") // JSON : budget, zone, taux, nbBiens, etc. (anonyme, pas de PII)
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}

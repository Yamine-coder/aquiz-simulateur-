{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/aides-health",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/scraping-health",
      "schedule": "0 7 * * *"
    }
  ]
}
